<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <ImageView
        android:id="@+id/bg_book"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/bg_image"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/vw_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/transparent"
        android:orientation="vertical">

        <io.legado.app.ui.widget.TitleBar
            android:id="@+id/title_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:themeMode="dark"
            app:title="@string/book_info" />

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/refresh_layout"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <io.legado.app.ui.widget.NoChildScrollNestedScrollView
                android:id="@+id/scroll_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:fitsSystemWindows="false"
                android:focusable="true"
                android:fadingEdge="none"
                android:overScrollMode="never"
                android:requiresFadingEdge="none"
                android:scrollbarStyle="outsideOverlay"
                android:scrollbars="vertical">

                <LinearLayout
                    android:id="@+id/ll_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="@dimen/ng_page_padding"
                    android:paddingTop="@dimen/ng_space_s"
                    android:paddingEnd="@dimen/ng_page_padding"
                    android:paddingBottom="@dimen/ng_space_l">

                    <io.legado.app.ui.widget.image.ArcView
                        android:id="@+id/arc_view"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:visibility="gone"
                        app:arcDirectionTop="true"
                        app:arcHeight="0dp"
                        app:bgColor="@color/transparent" />

                    <LinearLayout
                        style="@style/Ng.SettingsGroup"
                        android:background="@drawable/ng_bg_book_detail_card"
                        android:layout_marginTop="@dimen/ng_space_s"
                        android:gravity="top"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/ng_space_l"
                        android:paddingTop="@dimen/ng_space_l"
                        android:paddingEnd="@dimen/ng_space_l"
                        android:paddingBottom="@dimen/ng_space_l">

                        <io.legado.app.ui.widget.image.CoverImageView
                            android:id="@+id/iv_cover"
                            android:layout_width="78dp"
                            android:layout_height="104dp"
                            android:layout_gravity="top"
                            android:layout_marginEnd="@dimen/ng_space_l"
                            android:contentDescription="@string/img_cover"
                            android:scaleType="centerCrop"
                            android:src="@drawable/image_cover_default"
                            app:radius="@dimen/ng_radius_s" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="top"
                            android:orientation="vertical">

                            <io.legado.app.ui.widget.text.MarqueeTextView
                                android:id="@+id/tv_name"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:ellipsize="marquee"
                                android:includeFontPadding="false"
                                android:marqueeRepeatLimit="marquee_forever"
                                android:scrollHorizontally="true"
                                android:singleLine="true"
                                android:text="@string/book_name"
                                android:textColor="@color/primaryText"
                                android:textSize="17sp"
                                android:textStyle="bold"
                                tools:ignore="RtlHardcoded" />

                            <TextView
                                android:id="@+id/tv_author"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/ng_space_xs"
                                android:layout_marginBottom="@dimen/ng_space_m"
                                android:ellipsize="end"
                                android:includeFontPadding="false"
                                android:singleLine="true"
                                android:textColor="@color/tv_text_summary"
                                android:textSize="14sp"
                                tools:text="@string/author_show" />

                            <io.legado.app.ui.widget.WrapLabelsBar
                                android:id="@+id/lb_kind"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:visibility="gone" />

                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        style="@style/Ng.SettingsGroup"
                        android:background="@drawable/ng_bg_book_detail_card"
                        android:layout_marginTop="@dimen/ng_space_m"
                        android:paddingStart="@dimen/ng_space_l"
                        android:paddingTop="@dimen/ng_space_m"
                        android:paddingEnd="@dimen/ng_space_l"
                        android:paddingBottom="@dimen/ng_space_m">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingTop="5dp"
                            android:paddingBottom="5dp">

                            <ImageView
                                android:id="@+id/iv_web"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:contentDescription="@string/origin_format"
                                android:src="@drawable/ic_web_outline"
                                app:tint="@color/tv_text_summary" />

                            <TextView
                                android:id="@+id/tv_origin"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/ng_space_s"
                                android:layout_weight="1"
                                android:ellipsize="end"
                                android:includeFontPadding="false"
                                android:singleLine="true"
                                android:textColor="@color/tv_text_summary"
                                android:textSize="14sp"
                                tools:ignore="NestedWeights,RtlSymmetry"
                                tools:text="@string/origin_format" />

                            <ImageButton
                                android:id="@+id/tv_change_source"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginStart="@dimen/ng_space_s"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="@string/change_origin"
                                android:gravity="center"
                                android:padding="6dp"
                                android:scaleType="centerInside"
                                android:src="@drawable/ic_exchange"
                                app:tint="@color/tv_text_summary" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingTop="5dp"
                            android:paddingBottom="5dp"
                            tools:ignore="UseCompoundDrawables">

                            <ImageView
                                android:id="@+id/ic_book_last"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:contentDescription="@string/read_dur_progress"
                                android:src="@drawable/ic_book_last"
                                app:tint="@color/tv_text_summary" />

                            <TextView
                                android:id="@+id/tv_lasted"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/ng_space_s"
                                android:layout_weight="1"
                                android:ellipsize="end"
                                android:includeFontPadding="false"
                                android:singleLine="true"
                                android:textColor="@color/tv_text_summary"
                                android:textSize="14sp"
                                tools:ignore="NestedWeights,RtlSymmetry"
                                tools:text="@string/read_dur_progress" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingTop="5dp"
                            android:paddingBottom="5dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:contentDescription="@string/read_dur_progress"
                                android:src="@drawable/ic_groups"
                                app:tint="@color/tv_text_summary" />

                            <TextView
                                android:id="@+id/tv_group"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/ng_space_s"
                                android:layout_weight="1"
                                android:ellipsize="end"
                                android:includeFontPadding="false"
                                android:singleLine="true"
                                android:textColor="@color/tv_text_summary"
                                android:textSize="14sp"
                                tools:ignore="NestedWeights,RtlSymmetry"
                                tools:text="@string/group_s" />

                            <ImageButton
                                android:id="@+id/tv_change_group"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginStart="@dimen/ng_space_s"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="@string/change_group"
                                android:gravity="center"
                                android:padding="6dp"
                                android:scaleType="centerInside"
                                android:src="@drawable/ic_groups"
                                app:tint="@color/tv_text_summary" />

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/ll_toc"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingTop="5dp"
                            android:paddingBottom="5dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:contentDescription="@string/read_dur_progress"
                                android:src="@drawable/ic_folder_open"
                                app:tint="@color/tv_text_summary" />

                            <TextView
                                android:id="@+id/tv_toc"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/ng_space_s"
                                android:layout_weight="1"
                                android:ellipsize="end"
                                android:includeFontPadding="false"
                                android:singleLine="true"
                                android:textColor="@color/tv_text_summary"
                                android:textSize="14sp"
                                tools:ignore="NestedWeights,RtlSymmetry"
                                tools:text="@string/toc_s" />

                            <ImageButton
                                android:id="@+id/tv_toc_view"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginStart="@dimen/ng_space_s"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="@string/view_toc"
                                android:gravity="center"
                                android:padding="6dp"
                                android:scaleType="centerInside"
                                android:src="@drawable/ic_folder_open"
                                app:tint="@color/tv_text_summary" />

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/ll_cache"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingTop="5dp"
                            android:paddingBottom="5dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:contentDescription="@string/book_cache"
                                android:src="@drawable/ic_cache_octicon"
                                app:tint="@color/tv_text_summary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/ng_space_s"
                                android:includeFontPadding="false"
                                android:singleLine="true"
                                android:text="@string/book_cache_label"
                                android:textColor="@color/tv_text_summary"
                                android:textSize="14sp"
                                tools:ignore="RtlSymmetry" />

                            <io.legado.app.ui.book.search.SearchProgressTextView
                                android:id="@+id/tv_cache"
                                android:layout_width="0dp"
                                android:layout_height="24dp"
                                android:layout_weight="1"
                                android:ellipsize="end"
                                android:gravity="center_vertical"
                                android:includeFontPadding="false"
                                android:paddingStart="@dimen/ng_space_xs"
                                android:paddingEnd="@dimen/ng_space_s"
                                android:singleLine="true"
                                android:textColor="@color/tv_text_summary"
                                android:textSize="13sp"
                                tools:ignore="NestedWeights,RtlSymmetry"
                                tools:text="12/120" />

                            <ImageButton
                                android:id="@+id/tv_cache_book"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginStart="@dimen/ng_space_s"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="@string/book_cache"
                                android:gravity="center"
                                android:padding="6dp"
                                android:scaleType="centerInside"
                                android:src="@drawable/ic_download_line"
                                app:tint="@color/tv_text_summary" />

                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        style="@style/Ng.SettingsGroup"
                        android:background="@drawable/ng_bg_book_detail_card"
                        android:layout_marginTop="@dimen/ng_space_m"
                        android:minHeight="112dp"
                        android:paddingStart="@dimen/ng_space_l"
                        android:paddingTop="@dimen/ng_space_s"
                        android:paddingEnd="@dimen/ng_space_l"
                        android:paddingBottom="@dimen/ng_space_m">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:includeFontPadding="false"
                            android:text="@string/book_intro_short"
                            android:textColor="@color/primaryText"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <FrameLayout
                            android:id="@+id/tv_intro_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/ll_book_scan"
                        style="@style/Ng.SettingsGroup"
                        android:layout_marginTop="@dimen/ng_space_m"
                        android:background="@drawable/ng_bg_book_detail_card"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/ng_space_l"
                        android:paddingTop="@dimen/ng_space_m"
                        android:paddingEnd="@dimen/ng_space_l"
                        android:paddingBottom="@dimen/ng_space_m">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:contentDescription="@string/book_scan"
                            android:padding="3dp"
                            android:src="@drawable/ic_ai"
                            app:tint="@color/tv_text_summary" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/ng_space_m"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:includeFontPadding="false"
                                android:text="@string/book_scan"
                                android:textColor="@color/primaryText"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:includeFontPadding="false"
                                android:text="@string/book_scan_summary"
                                android:textColor="@color/tv_text_summary"
                                android:textSize="12sp" />

                        </LinearLayout>

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@string/book_scan"
                            android:src="@drawable/ic_chevron_right_20"
                            app:tint="@color/tv_text_summary" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/ll_characters"
                        style="@style/Ng.SettingsGroup"
                        android:layout_marginTop="@dimen/ng_space_m"
                        android:background="@drawable/ng_bg_book_detail_card"
                        android:orientation="vertical"
                        android:paddingStart="@dimen/ng_space_l"
                        android:paddingTop="@dimen/ng_space_s"
                        android:paddingEnd="@dimen/ng_space_l"
                        android:paddingBottom="4dp"
                        android:visibility="gone">

                        <LinearLayout
                            android:id="@+id/ll_character_header"
                            android:layout_width="match_parent"
                            android:layout_height="32dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tv_character_title"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:includeFontPadding="false"
                                android:text="@string/book_characters"
                                android:textColor="@color/primaryText"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <ImageButton
                                android:id="@+id/iv_character_ai_assistant"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginStart="@dimen/ng_space_xs"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="@string/ai_assistant"
                                android:gravity="center"
                                android:padding="7dp"
                                android:scaleType="fitCenter"
                                android:src="@drawable/ic_ai"
                                app:tint="@color/tv_text_summary" />

                        </LinearLayout>

                        <HorizontalScrollView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:overScrollMode="never"
                            android:scrollbars="none">

                            <LinearLayout
                                android:id="@+id/ll_character_preview"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal" />

                        </HorizontalScrollView>

                        <LinearLayout
                            android:id="@+id/ll_character_open"
                            android:layout_width="match_parent"
                            android:layout_height="20dp"
                            android:layout_marginTop="4dp"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="end|center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tv_character_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:includeFontPadding="false"
                                android:textColor="@color/tv_text_summary"
                                android:textSize="13sp"
                                tools:text="19个" />

                            <ImageButton
                                android:id="@+id/iv_character_open"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginStart="2dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="@string/book_characters"
                                android:gravity="center"
                                android:padding="2dp"
                                android:scaleType="fitCenter"
                                android:src="@drawable/ic_chevron_right_20"
                                app:tint="@color/tv_text_summary" />

                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/ll_other_works"
                        style="@style/Ng.SettingsGroup"
                        android:layout_marginTop="@dimen/ng_space_m"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/ng_bg_book_detail_card"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="@dimen/ng_space_l"
                            android:paddingEnd="@dimen/ng_space_l">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:includeFontPadding="false"
                                android:text="@string/book_other_works"
                                android:textColor="@color/primaryText"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <ImageButton
                                android:id="@+id/iv_other_works_refresh"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="@string/refresh"
                                android:gravity="center"
                                android:padding="5dp"
                                android:src="@drawable/ic_refresh_black_24dp"
                                app:tint="@color/tv_text_summary" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_other_works_state"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:includeFontPadding="false"
                            android:layout_marginTop="@dimen/ng_space_s"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp"
                            android:textColor="@color/tv_text_summary"
                            android:textSize="13sp"
                            android:visibility="gone" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rv_other_works"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/ng_space_s"
                            android:nestedScrollingEnabled="false"
                            android:overScrollMode="never"
                            android:visibility="gone"
                            tools:itemCount="2"
                            tools:listitem="@layout/item_search" />

                    </LinearLayout>

                </LinearLayout>

            </io.legado.app.ui.widget.NoChildScrollNestedScrollView>

        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        <LinearLayout
            android:id="@+id/fl_action"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:background="@color/transparent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/ng_page_padding"
            android:paddingTop="@dimen/ng_space_s"
            android:paddingEnd="@dimen/ng_page_padding"
            android:paddingBottom="@dimen/ng_space_s"
            app:layout_constraintBottom_toBottomOf="parent">

            <io.legado.app.ui.book.info.BookInfoActionButton
                android:id="@+id/tv_shelf"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1" />

            <io.legado.app.ui.book.info.BookInfoActionButton
                android:id="@+id/tv_listen"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_marginStart="@dimen/ng_space_s"
                android:layout_weight="1" />

            <io.legado.app.ui.book.info.BookInfoActionButton
                android:id="@+id/tv_read"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_marginStart="@dimen/ng_space_s"
                android:layout_weight="1.18" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
