<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/ng_bg_bottom_sheet"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <TextView
            android:id="@+id/button_close"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="start|center_vertical"
            android:gravity="center"
            android:text="×"
            android:textColor="@color/ng_on_surface"
            android:textSize="40sp" />

        <TextView
            style="@style/Ng.Title"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="@string/ai_edit_model"
            android:textSize="24sp" />

    </FrameLayout>

    <LinearLayout
        android:id="@+id/layout_tabs"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/tab_basic"
            style="@style/Ng.SettingsTitle"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/ai_model_basic_settings"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tab_advanced"
            style="@style/Ng.SettingsTitle"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:enabled="false"
            android:gravity="center"
            android:text="@string/ai_model_advanced_settings"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tab_builtin_tools"
            style="@style/Ng.SettingsTitle"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:enabled="false"
            android:gravity="center"
            android:text="@string/ai_model_builtin_tools"
            android:textSize="16sp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/ng_primary" />

        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent" />

        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:background="@color/ng_outline_strong" />

    <ScrollView
        android:id="@+id/scroll_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="false"
        android:overScrollMode="ifContentScrolls">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="18dp"
            android:paddingEnd="24dp"
            android:paddingBottom="24dp">

            <TextView
                style="@style/Ng.Label"
                android:layout_marginStart="12dp"
                android:text="@string/ai_model_id" />

            <EditText
                android:id="@+id/edit_model_id"
                style="@style/Ng.OutlinedField"
                android:layout_marginTop="6dp"
                android:enabled="false"
                android:singleLine="true" />

            <TextView
                style="@style/Ng.Label"
                android:layout_marginStart="12dp"
                android:layout_marginTop="16dp"
                android:text="@string/ai_model_display_name" />

            <EditText
                android:id="@+id/edit_model_display_name"
                style="@style/Ng.OutlinedField"
                android:layout_marginTop="6dp"
                android:singleLine="true" />

            <TextView
                style="@style/Ng.Label"
                android:layout_marginStart="12dp"
                android:layout_marginTop="18dp"
                android:text="@string/ai_model_type" />

            <LinearLayout
                android:id="@+id/layout_model_type"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:divider="@drawable/ng_divider_ai_segment"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/segment_model_type_chat"
                    style="@style/Ng.SettingsTitle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/ai_model_type_chat" />

                <TextView
                    android:id="@+id/segment_model_type_image"
                    style="@style/Ng.SettingsTitle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/ai_model_type_image" />

                <TextView
                    android:id="@+id/segment_model_type_embedding"
                    style="@style/Ng.SettingsTitle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/ai_model_type_embedding" />

                <TextView
                    android:id="@+id/segment_model_type_asr"
                    style="@style/Ng.SettingsTitle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/ai_model_type_asr" />

                <TextView
                    android:id="@+id/segment_model_type_tts"
                    style="@style/Ng.SettingsTitle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/ai_model_type_tts" />

                <TextView
                    android:id="@+id/segment_model_type_video"
                    style="@style/Ng.SettingsTitle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/ai_model_type_video" />

            </LinearLayout>

            <TextView
                android:id="@+id/text_model_input_modalities_label"
                style="@style/Ng.Label"
                android:layout_marginStart="12dp"
                android:layout_marginTop="18dp"
                android:text="@string/ai_model_input_modalities" />

            <LinearLayout
                android:id="@+id/layout_model_input_modalities"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:divider="@drawable/ng_divider_ai_segment"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/segment_model_input_text"
                    style="@style/Ng.SettingsTitle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/ai_model_modality_text" />

                <TextView
                    android:id="@+id/segment_model_input_image"
                    style="@style/Ng.SettingsTitle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/ai_model_modality_image" />

                <TextView
                    android:id="@+id/segment_model_input_video"
                    style="@style/Ng.SettingsTitle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/ai_model_modality_video" />

            </LinearLayout>

            <TextView
                android:id="@+id/text_model_output_modalities_label"
                style="@style/Ng.Label"
                android:layout_marginStart="12dp"
                android:layout_marginTop="18dp"
                android:text="@string/ai_model_output_modalities" />

            <LinearLayout
                android:id="@+id/layout_model_output_modalities"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:divider="@drawable/ng_divider_ai_segment"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/segment_model_output_text"
                    style="@style/Ng.SettingsTitle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/ai_model_modality_text" />

                <TextView
                    android:id="@+id/segment_model_output_image"
                    style="@style/Ng.SettingsTitle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/ai_model_modality_image" />

                <TextView
                    android:id="@+id/segment_model_output_video"
                    style="@style/Ng.SettingsTitle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/ai_model_modality_video" />

            </LinearLayout>

            <TextView
                android:id="@+id/text_model_abilities_label"
                style="@style/Ng.Label"
                android:layout_marginStart="12dp"
                android:layout_marginTop="18dp"
                android:text="@string/ai_model_abilities" />

            <LinearLayout
                android:id="@+id/layout_model_abilities"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:divider="@drawable/ng_divider_ai_segment"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/segment_model_ability_tool"
                    style="@style/Ng.SettingsTitle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/ai_model_ability_tool" />

                <TextView
                    android:id="@+id/segment_model_ability_reasoning"
                    style="@style/Ng.SettingsTitle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/ai_model_ability_reasoning" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:gravity="center_vertical|end"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <TextView
            android:id="@+id/button_cancel"
            style="@style/Ng.DialogButton"
            android:text="@string/cancel"
            android:textColor="@color/ng_primary" />

        <TextView
            android:id="@+id/button_confirm"
            style="@style/Ng.DialogButton"
            android:layout_marginStart="12dp"
            android:text="@string/sure"
            android:textColor="@color/ng_primary" />

    </LinearLayout>

</LinearLayout>
