<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="@dimen/ng_page_padding"
        android:paddingTop="@dimen/ng_space_l"
        android:paddingEnd="@dimen/ng_page_padding">

        <TextView
            android:id="@+id/text_section_label"
            style="@style/Ng.SettingsSectionLabel"
            android:text="@string/read_aloud_settings_section_features" />

        <io.legado.app.ui.widget.NgGlassLayout style="@style/Ng.SettingsGroup">

            <View style="@style/Ng.SettingsGroupEdgeSpace" />

            <LinearLayout
                android:id="@+id/layout_tts_engine_entry"
                style="@style/Ng.SettingsItem">

                <ImageView
                    android:id="@+id/image_tts_engine_icon"
                    style="@style/Ng.SettingsIconImage"
                    android:layout_gravity="center_vertical"
                    android:contentDescription="@string/tts_engine_settings"
                    android:src="@drawable/ic_ai_capability_tts" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Ng.SettingsTitle"
                        android:text="@string/tts_engine_settings" />

                    <TextView
                        style="@style/Ng.SettingsSummary"
                        android:layout_marginTop="4dp"
                        android:maxLines="1"
                        android:text="@string/tts_engine_settings_summary" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="@color/ng_settings_arrow"
                    android:textSize="30sp" />

            </LinearLayout>

            <View style="@style/Ng.SettingsItemGap" />

            <LinearLayout
                android:id="@+id/layout_multi_role_engine_entry"
                style="@style/Ng.SettingsItem">

                <ImageView
                    android:id="@+id/image_multi_role_engine_icon"
                    style="@style/Ng.SettingsIconImage"
                    android:layout_gravity="center_vertical"
                    android:contentDescription="@string/multi_role_tts_engine"
                    android:src="@drawable/ic_groups" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Ng.SettingsTitle"
                        android:text="@string/multi_role_tts_engine" />

                    <TextView
                        android:id="@+id/text_multi_role_engine_summary"
                        style="@style/Ng.SettingsSummary"
                        android:layout_marginTop="4dp"
                        android:ellipsize="end"
                        android:maxLines="1" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="@color/ng_settings_arrow"
                    android:textSize="30sp" />

            </LinearLayout>

            <View style="@style/Ng.SettingsItemGap" />

            <LinearLayout
                android:id="@+id/layout_default_voice_entry"
                style="@style/Ng.SettingsItem">

                <ImageView
                    android:id="@+id/image_default_voice_icon"
                    style="@style/Ng.SettingsIconImage"
                    android:layout_gravity="center_vertical"
                    android:contentDescription="@string/default_tts_voice"
                    android:src="@drawable/ic_tts_tab_voice" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Ng.SettingsTitle"
                        android:text="@string/default_tts_voice" />

                    <TextView
                        style="@style/Ng.SettingsSummary"
                        android:layout_marginTop="4dp"
                        android:maxLines="1"
                        android:text="@string/default_tts_voice_summary" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="@color/ng_settings_arrow"
                    android:textSize="30sp" />

            </LinearLayout>

            <View style="@style/Ng.SettingsGroupEdgeSpace" />

        </io.legado.app.ui.widget.NgGlassLayout>

    </LinearLayout>

</FrameLayout>
