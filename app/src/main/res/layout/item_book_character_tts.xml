<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/ng_bg_settings_item"
    android:gravity="center_vertical"
    android:minHeight="78dp"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingTop="12dp"
    android:paddingEnd="12dp"
    android:paddingBottom="12dp">

    <TextView
        android:id="@+id/tv_avatar"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_character_avatar_unknown"
        android:gravity="center"
        android:includeFontPadding="false"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        tools:text="旁" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/ng_space_m"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textColor="@color/primaryText"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="旁白" />

            <TextView
                android:id="@+id/tv_role"
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:layout_marginStart="@dimen/ng_space_s"
                android:background="@drawable/bg_character_tag"
                android:gravity="center"
                android:includeFontPadding="false"
                android:minWidth="40dp"
                android:paddingStart="7dp"
                android:paddingEnd="7dp"
                android:textColor="@color/tv_text_summary"
                android:textSize="12sp"
                tools:text="旁白" />

        </LinearLayout>

        <TextView
            android:id="@+id/tv_voice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:textColor="@color/tv_text_summary"
            android:textSize="14sp"
            tools:text="晓晓 · 少女感-温柔旁白" />

        <TextView
            android:id="@+id/tv_style"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:textColor="@color/secondaryText"
            android:textSize="13sp"
            tools:text="默认风格：无 · 情绪映射待配置" />

    </LinearLayout>

    <TextView
        android:id="@+id/tv_action"
        android:layout_width="wrap_content"
        android:layout_height="34dp"
        android:layout_marginStart="@dimen/ng_space_s"
        android:background="@drawable/bg_character_tag"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:gravity="center"
        android:minWidth="52dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:text="@string/character_tts_select_voice"
        android:textColor="@color/primaryText"
        android:textSize="13sp" />

</LinearLayout>
