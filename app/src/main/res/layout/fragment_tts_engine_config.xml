<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <LinearLayout
        android:id="@+id/layout_engine_list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="@dimen/ng_page_padding"
        android:paddingTop="@dimen/ng_space_l"
        android:paddingEnd="@dimen/ng_page_padding">

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/refresh_engines"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_engines"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="16dp" />

        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_engine_detail"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="@dimen/ng_page_padding"
        android:paddingTop="@dimen/ng_space_l"
        android:paddingEnd="@dimen/ng_page_padding"
        android:visibility="gone">

        <TextView
            android:id="@+id/text_detail_title"
            style="@style/Ng.CardTitle"
            android:ellipsize="end"
            android:singleLine="true"
            android:visibility="gone" />

        <FrameLayout
            android:id="@+id/scroll_config"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_weight="1">

            <ScrollView
                android:id="@+id/scroll_config_form"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="16dp">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_config_rules"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/enabled"
                            android:textColor="@color/ng_on_surface"
                            android:textSize="17sp" />

                        <io.legado.app.lib.theme.view.ThemeSwitch
                            android:id="@+id/switch_enabled"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                    </LinearLayout>

                </LinearLayout>

            </ScrollView>

            <LinearLayout
                android:id="@+id/layout_script_editor"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <io.legado.app.ui.widget.code.CodeView
                    android:id="@+id/edit_script_code"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:background="@drawable/ng_bg_outlined_field"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:minHeight="220dp"
                    android:paddingStart="10dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="8dp"
                    android:textColor="@color/ng_on_surface"
                    android:textSize="15sp" />

            </LinearLayout>

        </FrameLayout>

        <LinearLayout
            android:id="@+id/layout_config_actions"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <io.legado.app.ui.widget.text.AccentStrokeTextView
                android:id="@+id/button_config_source"
                style="@style/Ng.SmallButton.Secondary"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:text="@string/tts_source_mode" />

            <io.legado.app.ui.widget.text.AccentStrokeTextView
                android:id="@+id/button_save_config"
                style="@style/Ng.SmallButton.Secondary"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="@string/save" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_voices"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="14dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/layout_voice_search"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginBottom="2dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    style="@style/Ng.SearchPill"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_search"
                        android:tint="@color/tv_text_summary" />

                    <EditText
                        android:id="@+id/edit_search_voice"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="@string/tts_search_voice"
                        android:singleLine="true"
                        android:textColor="@color/tv_text_summary"
                        android:textColorHint="@color/tv_text_summary"
                        android:textSize="15sp" />

                </LinearLayout>

                <io.legado.app.ui.widget.image.AccentStrokeImageButton
                    android:id="@+id/button_voice_params"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="8dp"
                    android:contentDescription="@string/tts_voice_params"
                    android:padding="8dp"
                    android:src="@drawable/ic_tts_params_grid" />

            </LinearLayout>

            <TextView
                android:id="@+id/text_voice_message"
                style="@style/Ng.SettingsSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/tts_voice_not_loaded"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layout_system_voice_params"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/ng_bg_tts_param_popup"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingTop="14dp"
                android:paddingEnd="18dp"
                android:paddingBottom="14dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        style="@style/Ng.Label"
                        android:layout_width="40dp"
                        android:text="@string/tts_speed" />

                    <androidx.appcompat.widget.AppCompatSeekBar
                        android:id="@+id/seek_system_speed"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:max="100"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:progressDrawable="@drawable/ng_tts_param_seek_progress"
                        android:splitTrack="false"
                        android:thumb="@drawable/ng_tts_param_seek_thumb"
                        android:thumbTint="@color/white" />

                    <TextView
                        android:id="@+id/text_system_speed_value"
                        style="@style/Ng.SettingsSummary"
                        android:layout_width="36dp"
                        android:gravity="end" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        style="@style/Ng.Label"
                        android:layout_width="40dp"
                        android:text="@string/tts_pitch" />

                    <androidx.appcompat.widget.AppCompatSeekBar
                        android:id="@+id/seek_system_pitch"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:max="100"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:progressDrawable="@drawable/ng_tts_param_seek_progress"
                        android:splitTrack="false"
                        android:thumb="@drawable/ng_tts_param_seek_thumb"
                        android:thumbTint="@color/white" />

                    <TextView
                        android:id="@+id/text_system_pitch_value"
                        style="@style/Ng.SettingsSummary"
                        android:layout_width="36dp"
                        android:gravity="end" />

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_voice_header"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    style="@style/Ng.Title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/tts_voices"
                    android:textColor="@color/ng_on_surface"
                    android:textSize="17sp" />

                <io.legado.app.ui.widget.text.AccentTextView
                    android:id="@+id/button_toggle_all_voices"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:minWidth="66dp"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:text="@string/tts_disable_all_voices"
                    android:textSize="15sp" />

            </LinearLayout>

            <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                android:id="@+id/refresh_voices"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="6dp"
                android:layout_weight="1">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_voices"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:paddingBottom="16dp" />

            </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_engine_detail_tabs"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@android:color/transparent"
            android:gravity="center"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clipChildren="false"
                android:clipToPadding="false">

                <ImageButton
                    android:id="@+id/button_tab_config"
                    android:layout_width="68dp"
                    android:layout_height="34dp"
                    android:layout_gravity="center"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/tts_config_tab"
                    android:padding="6dp"
                    android:scaleType="center"
                    android:src="@drawable/ic_ai_tab_config"
                    android:tint="@color/ng_on_surface" />

            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clipChildren="false"
                android:clipToPadding="false">

                <ImageButton
                    android:id="@+id/button_tab_voices"
                    android:layout_width="68dp"
                    android:layout_height="34dp"
                    android:layout_gravity="center"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/tts_voices"
                    android:padding="6dp"
                    android:scaleType="center"
                    android:src="@drawable/ic_tts_tab_voice"
                    android:tint="@color/ng_on_surface_variant" />

            </FrameLayout>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
