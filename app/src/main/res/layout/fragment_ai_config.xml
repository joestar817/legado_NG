<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <LinearLayout
        android:id="@+id/layout_main_menu"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="@dimen/ng_page_padding"
        android:paddingTop="@dimen/ng_space_l"
        android:paddingEnd="@dimen/ng_page_padding">

        <TextView
            android:id="@+id/text_main_section_label"
            style="@style/Ng.SettingsSectionLabel"
            android:text="@string/ai_settings_section_features" />

        <io.legado.app.ui.widget.NgGlassLayout style="@style/Ng.SettingsGroup">

            <View style="@style/Ng.SettingsGroupEdgeSpace" />

            <LinearLayout
                android:id="@+id/layout_provider_entry"
                style="@style/Ng.SettingsItem">

                <ImageView
                    android:id="@+id/image_provider_entry_icon"
                    style="@style/Ng.SettingsIconImage"
                    android:layout_gravity="center_vertical"
                    android:contentDescription="@string/ai_provider_menu"
                    android:src="@drawable/ic_ai_provider" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Ng.SettingsTitle"
                        android:text="@string/ai_provider_menu" />

                    <TextView
                        android:id="@+id/text_provider_entry_summary"
                        style="@style/Ng.SettingsSummary"
                        android:layout_marginTop="4dp"
                        android:maxLines="1" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="@color/ng_settings_arrow"
                    android:textSize="30sp" />

            </LinearLayout>

            <View style="@style/Ng.SettingsItemGap" />

            <LinearLayout
                android:id="@+id/layout_prompt_entry"
                style="@style/Ng.SettingsItem">

                <ImageView
                    android:id="@+id/image_prompt_entry_icon"
                    style="@style/Ng.SettingsIconImage"
                    android:layout_gravity="center_vertical"
                    android:contentDescription="@string/ai_prompt_menu"
                    android:src="@drawable/ic_ai_prompt" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Ng.SettingsTitle"
                        android:text="@string/ai_prompt_menu" />

                    <TextView
                        android:id="@+id/text_prompt_entry_summary"
                        style="@style/Ng.SettingsSummary"
                        android:layout_marginTop="4dp"
                        android:maxLines="1" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="@color/ng_settings_arrow"
                    android:textSize="30sp" />

            </LinearLayout>

            <View style="@style/Ng.SettingsItemGap" />

            <LinearLayout
                android:id="@+id/layout_purify_entry"
                style="@style/Ng.SettingsItem">

                <ImageView
                    android:id="@+id/image_purify_entry_icon"
                    style="@style/Ng.SettingsIconImage"
                    android:layout_gravity="center_vertical"
                    android:contentDescription="@string/ai_purify_settings"
                    android:src="@drawable/ic_ai_purify" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Ng.SettingsTitle"
                        android:text="@string/ai_purify_settings" />

                    <TextView
                        android:id="@+id/text_purify_entry_summary"
                        style="@style/Ng.SettingsSummary"
                        android:layout_marginTop="4dp"
                        android:maxLines="1" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="@color/ng_settings_arrow"
                    android:textSize="30sp" />

            </LinearLayout>

            <View style="@style/Ng.SettingsGroupEdgeSpace" />

        </io.legado.app.ui.widget.NgGlassLayout>

    </LinearLayout>

    <ScrollView
        android:id="@+id/layout_purify_settings"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/ng_page_padding"
            android:paddingTop="8dp"
            android:paddingEnd="@dimen/ng_page_padding"
            android:paddingBottom="20dp">

            <TextView
                android:id="@+id/text_purify_section_label"
                style="@style/Ng.SettingsSectionLabel"
                android:text="@string/ai_purify_paragraph_section" />

            <LinearLayout style="@style/Ng.SettingsGroup">

            <View style="@style/Ng.SettingsGroupEdgeSpace" />

            <LinearLayout
                android:id="@+id/layout_ai_purify_auto"
                style="@style/Ng.SettingsItem"
                android:clickable="false"
                android:focusable="false"
                android:foreground="@null">

                <ImageView
                    android:id="@+id/image_purify_auto_icon"
                    style="@style/Ng.SettingsIconImage"
                    android:layout_gravity="center_vertical"
                    android:contentDescription="@string/ai_purify_auto_apply"
                    android:src="@drawable/ic_ai_purify" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Ng.SettingsTitle"
                        android:text="@string/ai_purify_auto_apply" />

                    <TextView
                        android:id="@+id/text_ai_purify_auto_summary"
                        style="@style/Ng.SettingsSummary"
                        android:layout_marginTop="4dp"
                        android:maxLines="2"
                        android:text="@string/ai_purify_auto_apply_summary" />

                </LinearLayout>

                <Switch
                    android:id="@+id/switch_ai_purify_auto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <View style="@style/Ng.SettingsItemGap" />

            <LinearLayout
                android:id="@+id/layout_ai_purify_intercept"
                style="@style/Ng.SettingsItem"
                android:clickable="false"
                android:focusable="false"
                android:foreground="@null">

                <ImageView
                    android:id="@+id/image_purify_intercept_icon"
                    style="@style/Ng.SettingsIconImage"
                    android:layout_gravity="center_vertical"
                    android:contentDescription="@string/ai_purify_exception_intercept"
                    android:src="@drawable/ic_ai_provider" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Ng.SettingsTitle"
                        android:text="@string/ai_purify_exception_intercept" />

                    <TextView
                        style="@style/Ng.SettingsSummary"
                        android:layout_marginTop="4dp"
                        android:maxLines="2"
                        android:text="@string/ai_purify_exception_intercept_summary" />

                </LinearLayout>

                <Switch
                    android:id="@+id/switch_ai_purify_intercept"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <View style="@style/Ng.SettingsItemGap" />

            <LinearLayout
                style="@style/Ng.SettingsItem"
                android:clickable="false"
                android:focusable="false"
                android:foreground="@null">

                <ImageView
                    android:id="@+id/image_purify_limit_icon"
                    style="@style/Ng.SettingsIconImage"
                    android:layout_gravity="center_vertical"
                    android:contentDescription="@string/ai_purify_paragraph_limit"
                    android:src="@drawable/ic_ai_prompt" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Ng.SettingsTitle"
                        android:text="@string/ai_purify_paragraph_limit" />

                    <TextView
                        style="@style/Ng.SettingsSummary"
                        android:layout_marginTop="4dp"
                        android:maxLines="1"
                        android:text="@string/ai_purify_paragraph_limit_summary" />

                </LinearLayout>

                <EditText
                    android:id="@+id/edit_purify_paragraph_limit"
                    style="@style/Ng.OutlinedField.Compact"
                    android:layout_width="92dp"
                    android:layout_marginStart="12dp"
                    android:gravity="center"
                    android:inputType="number"
                    android:singleLine="true" />

            </LinearLayout>

            <View style="@style/Ng.SettingsGroupEdgeSpace" />

            </LinearLayout>

            <TextView
                android:id="@+id/text_purify_chapter_section_label"
                style="@style/Ng.SettingsSectionLabel"
                android:layout_marginTop="18dp"
                android:text="@string/ai_purify_chapter_section" />

            <LinearLayout style="@style/Ng.SettingsGroup">

                <View style="@style/Ng.SettingsGroupEdgeSpace" />

                <LinearLayout
                    android:id="@+id/layout_ai_purify_chapter_auto"
                    style="@style/Ng.SettingsItem"
                    android:clickable="false"
                    android:focusable="false"
                    android:foreground="@null">

                    <ImageView
                        android:id="@+id/image_purify_chapter_auto_icon"
                        style="@style/Ng.SettingsIconImage"
                        android:layout_gravity="center_vertical"
                        android:contentDescription="@string/ai_purify_auto_apply"
                        android:src="@drawable/ic_ai_purify" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/Ng.SettingsTitle"
                            android:text="@string/ai_purify_auto_apply" />

                        <TextView
                            android:id="@+id/text_ai_purify_chapter_auto_summary"
                            style="@style/Ng.SettingsSummary"
                            android:layout_marginTop="4dp"
                            android:maxLines="2"
                            android:text="@string/ai_purify_auto_apply_summary" />

                    </LinearLayout>

                    <Switch
                        android:id="@+id/switch_ai_purify_chapter_auto"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

                <View style="@style/Ng.SettingsItemGap" />

                <LinearLayout
                    android:id="@+id/layout_ai_purify_chapter_intercept"
                    style="@style/Ng.SettingsItem"
                    android:clickable="false"
                    android:focusable="false"
                    android:foreground="@null">

                    <ImageView
                        android:id="@+id/image_purify_chapter_intercept_icon"
                        style="@style/Ng.SettingsIconImage"
                        android:layout_gravity="center_vertical"
                        android:contentDescription="@string/ai_purify_exception_intercept"
                        android:src="@drawable/ic_ai_provider" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/Ng.SettingsTitle"
                            android:text="@string/ai_purify_exception_intercept" />

                        <TextView
                            style="@style/Ng.SettingsSummary"
                            android:layout_marginTop="4dp"
                            android:maxLines="2"
                            android:text="@string/ai_purify_chapter_exception_intercept_summary" />

                    </LinearLayout>

                    <Switch
                        android:id="@+id/switch_ai_purify_chapter_intercept"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

                <View style="@style/Ng.SettingsItemGap" />

                <LinearLayout
                    android:id="@+id/layout_ai_purify_chapter_rule_types"
                    style="@style/Ng.SettingsItem">

                    <ImageView
                        android:id="@+id/image_purify_chapter_rule_types_icon"
                        style="@style/Ng.SettingsIconImage"
                        android:layout_gravity="center_vertical"
                        android:contentDescription="@string/ai_purify_chapter_rule_types"
                        android:src="@drawable/ic_find_replace" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/Ng.SettingsTitle"
                            android:text="@string/ai_purify_chapter_rule_types" />

                        <TextView
                            android:id="@+id/text_ai_purify_chapter_rule_types_summary"
                            style="@style/Ng.SettingsSummary"
                            android:layout_marginTop="4dp"
                            android:maxLines="1" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="@color/ng_settings_arrow"
                        android:textSize="30sp" />

                </LinearLayout>

                <View style="@style/Ng.SettingsItemGap" />

                <LinearLayout
                    style="@style/Ng.SettingsItem"
                    android:clickable="false"
                    android:focusable="false"
                    android:foreground="@null">

                    <ImageView
                        android:id="@+id/image_purify_chapter_concurrency_icon"
                        style="@style/Ng.SettingsIconImage"
                        android:layout_gravity="center_vertical"
                        android:contentDescription="@string/ai_purify_chapter_concurrency_limit"
                        android:src="@drawable/ic_ai_prompt" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/Ng.SettingsTitle"
                            android:text="@string/ai_purify_chapter_concurrency_limit" />

                        <TextView
                            style="@style/Ng.SettingsSummary"
                            android:layout_marginTop="4dp"
                            android:maxLines="1"
                            android:text="@string/ai_purify_chapter_concurrency_limit_summary" />

                    </LinearLayout>

                    <EditText
                        android:id="@+id/edit_purify_chapter_concurrency_limit"
                        style="@style/Ng.OutlinedField.Compact"
                        android:layout_width="92dp"
                        android:layout_marginStart="12dp"
                        android:gravity="center"
                        android:inputType="number"
                        android:singleLine="true" />

                </LinearLayout>

                <View style="@style/Ng.SettingsItemGap" />

                <LinearLayout
                    style="@style/Ng.SettingsItem"
                    android:clickable="false"
                    android:focusable="false"
                    android:foreground="@null">

                    <ImageView
                        android:id="@+id/image_purify_chapter_retry_icon"
                        style="@style/Ng.SettingsIconImage"
                        android:layout_gravity="center_vertical"
                        android:contentDescription="@string/ai_purify_chapter_retry_count"
                        android:src="@drawable/ic_ai_prompt" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/Ng.SettingsTitle"
                            android:text="@string/ai_purify_chapter_retry_count" />

                        <TextView
                            style="@style/Ng.SettingsSummary"
                            android:layout_marginTop="4dp"
                            android:maxLines="1"
                            android:text="@string/ai_purify_chapter_retry_count_summary" />

                    </LinearLayout>

                    <EditText
                        android:id="@+id/edit_purify_chapter_retry_count"
                        style="@style/Ng.OutlinedField.Compact"
                        android:layout_width="92dp"
                        android:layout_marginStart="12dp"
                        android:gravity="center"
                        android:inputType="number"
                        android:singleLine="true" />

                </LinearLayout>

                <View style="@style/Ng.SettingsItemGap" />

                <LinearLayout
                    style="@style/Ng.SettingsItem"
                    android:clickable="false"
                    android:focusable="false"
                    android:foreground="@null">

                    <ImageView
                        android:id="@+id/image_purify_chapter_limit_icon"
                        style="@style/Ng.SettingsIconImage"
                        android:layout_gravity="center_vertical"
                        android:contentDescription="@string/ai_purify_chapter_segment_limit"
                        android:src="@drawable/ic_ai_prompt" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/Ng.SettingsTitle"
                            android:text="@string/ai_purify_chapter_segment_limit" />

                        <TextView
                            style="@style/Ng.SettingsSummary"
                            android:layout_marginTop="4dp"
                            android:maxLines="1"
                            android:text="@string/ai_purify_chapter_segment_limit_summary" />

                    </LinearLayout>

                    <EditText
                        android:id="@+id/edit_purify_chapter_segment_limit"
                        style="@style/Ng.OutlinedField.Compact"
                        android:layout_width="92dp"
                        android:layout_marginStart="12dp"
                        android:gravity="center"
                        android:inputType="number"
                        android:singleLine="true" />

                </LinearLayout>

                <View style="@style/Ng.SettingsItemGap" />

                <LinearLayout
                    style="@style/Ng.SettingsItem"
                    android:clickable="false"
                    android:focusable="false"
                    android:foreground="@null">

                    <ImageView
                        android:id="@+id/image_purify_chapter_sample_limit_icon"
                        style="@style/Ng.SettingsIconImage"
                        android:layout_gravity="center_vertical"
                        android:contentDescription="@string/ai_purify_chapter_sample_limit"
                        android:src="@drawable/ic_ai_prompt" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/Ng.SettingsTitle"
                            android:text="@string/ai_purify_chapter_sample_limit" />

                        <TextView
                            style="@style/Ng.SettingsSummary"
                            android:layout_marginTop="4dp"
                            android:maxLines="1"
                            android:text="@string/ai_purify_chapter_sample_limit_summary" />

                    </LinearLayout>

                    <EditText
                        android:id="@+id/edit_purify_chapter_sample_limit"
                        style="@style/Ng.OutlinedField.Compact"
                        android:layout_width="92dp"
                        android:layout_marginStart="12dp"
                        android:gravity="center"
                        android:inputType="number"
                        android:singleLine="true" />

                </LinearLayout>

                <View style="@style/Ng.SettingsGroupEdgeSpace" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <LinearLayout
        android:id="@+id/layout_prompt_list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="@dimen/ng_page_padding"
        android:paddingTop="8dp"
        android:paddingEnd="@dimen/ng_page_padding"
        android:visibility="gone">

        <TextView
            style="@style/Ng.Summary"
            android:layout_marginBottom="14dp"
            android:text="@string/ai_prompt_protocol_summary" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_prompts"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="16dp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_prompt_detail"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="@dimen/ng_page_padding"
        android:paddingTop="8dp"
        android:paddingEnd="@dimen/ng_page_padding"
        android:visibility="gone">

        <TextView
            android:id="@+id/text_prompt_detail_title"
            style="@style/Ng.Title"
            android:layout_width="match_parent"
            android:textSize="24sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/text_prompt_detail_summary"
            style="@style/Ng.Summary"
            android:layout_marginTop="8dp"
            android:maxLines="3"
            android:visibility="gone" />

        <EditText
            android:id="@+id/edit_prompt"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/ng_bg_outlined_field"
            android:fontFamily="monospace"
            android:gravity="top|start"
            android:inputType="textMultiLine|textNoSuggestions"
            android:minLines="12"
            android:paddingStart="16dp"
            android:paddingTop="14dp"
            android:paddingEnd="16dp"
            android:paddingBottom="14dp"
            android:scrollbarStyle="insideInset"
            android:scrollbars="vertical"
            android:textColor="@color/ng_on_surface"
            android:textColorHint="@color/ng_on_surface_variant"
            android:textSize="13sp" />

        <LinearLayout
            style="@style/Ng.ActionBar"
            android:gravity="center_vertical|end"
            android:orientation="horizontal">

            <Button
                android:id="@+id/button_reset_prompt"
                style="@style/Ng.SmallButton.Secondary"
                android:text="@string/ai_prompt_reset" />

            <Button
                android:id="@+id/button_save_prompt"
                style="@style/Ng.SmallButton.Primary"
                android:layout_marginStart="16dp"
                android:text="@string/save" />

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_provider_list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="@dimen/ng_page_padding"
        android:paddingTop="8dp"
        android:paddingEnd="@dimen/ng_page_padding"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/layout_search"
            style="@style/Ng.SearchPill"
            android:layout_marginBottom="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_search"
                android:tint="@color/tv_text_summary" />

            <EditText
                android:id="@+id/edit_search_provider"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="@string/ai_search_provider"
                android:singleLine="true"
                android:textColor="@color/tv_text_summary"
                android:textColorHint="@color/tv_text_summary"
                android:textSize="16sp" />

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_providers"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="14dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="16dp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_provider_detail"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <ScrollView
            android:id="@+id/scroll_detail"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/ng_page_padding"
                android:paddingTop="16dp"
                android:paddingEnd="@dimen/ng_page_padding"
                android:paddingBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/ng_bg_icon_circle"
                        android:padding="8dp">

                        <ImageView
                            android:id="@+id/image_detail_icon"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/ai_provider_menu"
                            android:scaleType="fitCenter" />

                    </FrameLayout>

                    <TextView
                        android:id="@+id/text_detail_title"
                        style="@style/Ng.Title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:singleLine="true"
                        android:textSize="22sp" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_config_tab"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Ng.Label"
                        android:layout_marginTop="8dp"
                        android:layout_marginStart="12dp"
                        android:text="@string/ai_provider_name" />

                    <EditText
                        android:id="@+id/edit_provider_name"
                        style="@style/Ng.OutlinedField.Compact"
                        android:layout_marginTop="6dp"
                        android:singleLine="true" />

                    <TextView
                        style="@style/Ng.Label"
                        android:layout_marginTop="8dp"
                        android:layout_marginStart="12dp"
                        android:text="@string/ai_api_key" />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="34dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/ng_bg_outlined_field">

                        <EditText
                            android:id="@+id/edit_api_key"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:gravity="center_vertical"
                            android:includeFontPadding="false"
                            android:inputType="textPassword"
                            android:paddingStart="10dp"
                            android:paddingTop="0dp"
                            android:paddingEnd="42dp"
                            android:paddingBottom="0dp"
                            android:singleLine="true"
                            android:textColor="@color/ng_on_surface"
                            android:textColorHint="@color/ng_on_surface_variant"
                            android:textSize="13sp" />

                        <ImageButton
                            android:id="@+id/button_toggle_api_key"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:layout_gravity="end|center_vertical"
                            android:background="?android:attr/selectableItemBackgroundBorderless"
                            android:contentDescription="@string/ai_api_key_toggle_visibility"
                            android:padding="7dp"
                            android:src="@drawable/ic_visibility_off"
                            android:tint="@color/ng_on_surface_variant" />

                    </FrameLayout>

                    <TextView
                        style="@style/Ng.Label"
                        android:layout_marginTop="8dp"
                        android:layout_marginStart="12dp"
                        android:text="@string/ai_base_url" />

                    <EditText
                        android:id="@+id/edit_base_url"
                        style="@style/Ng.OutlinedField.Compact"
                        android:layout_marginTop="6dp"
                        android:inputType="textUri"
                        android:singleLine="true" />

                    <TextView
                        style="@style/Ng.Label"
                        android:layout_marginTop="8dp"
                        android:layout_marginStart="12dp"
                        android:text="@string/ai_model" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="34dp"
                        android:layout_marginTop="6dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <Spinner
                            android:id="@+id/spinner_model"
                            style="@style/Ng.Spinner.Compact"
                            android:layout_width="0dp"
                            android:layout_weight="1" />

                        <ImageButton
                            android:id="@+id/button_fetch_models"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/ng_bg_button_secondary"
                            android:contentDescription="@string/ai_fetch_models"
                            android:src="@drawable/ic_refresh_black_24dp"
                            android:tint="@color/ng_primary" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/text_openai_path_label"
                        style="@style/Ng.Label"
                        android:layout_marginTop="8dp"
                        android:layout_marginStart="12dp"
                        android:text="@string/ai_chat_completions_path" />

                    <EditText
                        android:id="@+id/edit_chat_path"
                        style="@style/Ng.OutlinedField.Compact"
                        android:layout_marginTop="6dp"
                        android:singleLine="true" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/ai_enabled"
                            android:textColor="@color/ng_on_surface"
                            android:textSize="17sp" />

                        <Switch
                            android:id="@+id/switch_enabled"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/text_models_url_label"
                        style="@style/Ng.Label"
                        android:layout_marginTop="8dp"
                        android:layout_marginStart="12dp"
                        android:text="@string/ai_models_url" />

                    <EditText
                        android:id="@+id/edit_models_url"
                        style="@style/Ng.OutlinedField.Compact"
                        android:layout_marginTop="6dp"
                        android:hint="@string/ai_models_url_summary"
                        android:inputType="textUri"
                        android:singleLine="true" />

                    <TextView
                        style="@style/Ng.Label"
                        android:layout_marginTop="8dp"
                        android:layout_marginStart="12dp"
                        android:text="@string/ai_timeout_seconds" />

                    <EditText
                        android:id="@+id/edit_timeout_seconds"
                        style="@style/Ng.OutlinedField.Compact"
                        android:layout_marginTop="6dp"
                        android:inputType="number"
                        android:singleLine="true" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:layout_marginTop="14dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/button_test_connection"
                            style="@style/Ng.SmallButton.Secondary"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:text="@string/ai_test_connection" />

                        <Button
                            android:id="@+id/button_query_balance"
                            style="@style/Ng.SmallButton.Secondary"
                            android:layout_width="0dp"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:text="@string/ai_query_balance" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

</FrameLayout>
