<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/ng_bg_book_detail_card"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingTop="16dp"
    android:paddingEnd="14dp"
    android:paddingBottom="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:text="旁白" />

        <TextView
            android:id="@+id/tv_speaker"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:includeFontPadding="false"
            android:lineSpacingExtra="2dp"
            android:maxLines="1"
            android:textColor="@color/tv_text_summary"
            android:textSize="14sp"
            tools:text="· 第 1 段" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/btn_preview"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="@string/tts_preview"
            android:foreground="?android:attr/selectableItemBackgroundBorderless"
            android:padding="10dp"
            android:src="@drawable/ic_tts_headphones" />

    </LinearLayout>

    <TextView
        android:id="@+id/tv_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:ellipsize="end"
        android:lineSpacingExtra="6dp"
        android:maxLines="6"
        android:textColor="@color/primaryText"
        android:textSize="16sp"
        tools:text="陈升，你站起来。" />

    <TextView
        android:id="@+id/tv_evidence"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:ellipsize="end"
        android:includeFontPadding="false"
        android:lineSpacingExtra="2dp"
        android:maxLines="2"
        android:textColor="@color/secondaryText"
        android:textSize="12sp"
        tools:text="第 3 段 · AI归因：前文刘翠霞站在讲台前，后文动作线索指向刘翠霞" />

</LinearLayout>
