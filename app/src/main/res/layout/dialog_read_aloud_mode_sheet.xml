<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_view"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/ng_bg_read_aloud_sheet"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="18dp"
    android:paddingEnd="20dp"
    android:paddingBottom="28dp">

    <TextView
        style="@style/Ng.Title"
        android:layout_width="match_parent"
        android:gravity="center"
        android:text="朗读模式" />

    <LinearLayout
        style="@style/Ng.DialogSection"
        android:layout_marginTop="18dp"
        android:orientation="vertical"
        android:padding="0dp">

        <LinearLayout
            android:id="@+id/item_multi_role"
            style="@style/Ng.SettingsItem"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            android:paddingStart="20dp"
            android:paddingEnd="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/Ng.SettingsTitle"
                    android:text="多人模式" />

                <TextView
                    android:id="@+id/text_multi_role_summary"
                    style="@style/Ng.SettingsSummary"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <io.legado.app.lib.theme.view.ThemeSwitch
                android:id="@+id/switch_multi_role"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/item_storyboard_result"
            style="@style/Ng.SettingsItem"
            android:layout_marginTop="6dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            android:paddingStart="20dp"
            android:paddingEnd="18dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/Ng.SettingsTitle"
                    android:text="分镜结果" />

                <TextView
                    style="@style/Ng.SettingsSummary"
                    android:layout_marginTop="4dp"
                    android:text="查看当前章节的角色分配和片段拆分" />
            </LinearLayout>

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_chevron_right_20"
                app:tint="@color/ng_on_surface_variant" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        style="@style/Ng.SettingsSectionLabel"
        android:layout_marginTop="18dp"
        android:text="分镜模式" />

    <LinearLayout
        android:id="@+id/layout_storyboard_mode"
        style="@style/Ng.DialogSection"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="22dp"
        android:paddingEnd="20dp"
        android:paddingBottom="18dp">

        <TextView
            android:id="@+id/tv_storyboard_mode_title"
            style="@style/Ng.SettingsTitle"
            android:layout_width="match_parent"
            android:text="基础模式" />

        <TextView
            android:id="@+id/tv_storyboard_mode_summary"
            style="@style/Ng.SettingsSummary"
            android:layout_width="match_parent"
            android:layout_marginTop="6dp"
            android:text="只做对白拆分和角色音色路由" />

        <SeekBar
            android:id="@+id/seek_storyboard_mode"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="16dp"
            android:max="3"
            android:maxHeight="6dp"
            android:minHeight="6dp"
            android:progress="0"
            android:progressDrawable="@drawable/ng_read_aloud_progress"
            android:splitTrack="false"
            android:thumb="@drawable/ng_read_aloud_seek_thumb"
            android:thumbOffset="11dp"
            android:tickMark="@drawable/ng_read_aloud_storyboard_mode_tick" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_storyboard_mode_basic"
                style="@style/Ng.SettingsSummary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="start"
                android:text="基础" />

            <TextView
                android:id="@+id/tv_storyboard_mode_advanced"
                style="@style/Ng.SettingsSummary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="进阶" />

            <TextView
                android:id="@+id/tv_storyboard_mode_director"
                style="@style/Ng.SettingsSummary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="导演" />

            <TextView
                android:id="@+id/tv_storyboard_mode_actor"
                style="@style/Ng.SettingsSummary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:text="演员" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
