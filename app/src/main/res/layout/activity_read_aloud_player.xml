<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingTop="84dp"
        android:paddingEnd="28dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="172dp"
            android:layout_height="200dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/ng_bg_read_aloud_cover_glass"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingTop="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="10dp">

            <ImageView
                android:id="@+id/iv_cover"
                android:layout_width="108dp"
                android:layout_height="144dp"
                android:background="@drawable/ng_bg_read_aloud_player_cover"
                android:clipToOutline="true"
                android:outlineProvider="background"
                android:scaleType="centerCrop"
                android:src="@drawable/icon_read_book" />

            <TextView
                android:id="@+id/tv_book"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:ellipsize="end"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textColor="@color/ng_on_surface_variant"
                android:textSize="14sp"
                tools:text="山河稷 · 姬叉" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/card_subtitle"
            android:layout_width="match_parent"
            android:layout_height="172dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/ng_bg_read_aloud_subtitle_card"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="14dp"
            android:paddingEnd="18dp"
            android:paddingBottom="14dp">

            <TextView
                android:id="@+id/tv_chapter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textColor="@color/ng_on_surface"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="第3章 野外世界" />

            <TextView
                android:id="@+id/tv_subtitle"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="10dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:gravity="center"
                android:lineSpacingExtra="6dp"
                android:maxLines="3"
                android:text="正在准备朗读..."
                android:textColor="@color/ng_on_surface"
                android:textSize="17sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:orientation="horizontal">

            <include
                android:id="@+id/action_timer"
                layout="@layout/view_read_aloud_player_quick_action"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <include
                android:id="@+id/action_speed"
                layout="@layout/view_read_aloud_player_quick_action"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <include
                android:id="@+id/action_original"
                layout="@layout/view_read_aloud_player_quick_action"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <include
                android:id="@+id/action_more"
                layout="@layout/view_read_aloud_player_quick_action"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btn_prev_paragraph"
                android:layout_width="42dp"
                android:layout_height="40dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/prev_sentence"
                android:padding="9dp"
                android:src="@drawable/ic_read_aloud_fast_rewind"
                app:tint="@color/ng_on_surface_variant" />

            <ProgressBar
                android:id="@+id/progress_chapter"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_weight="1"
                android:max="100"
                android:progressDrawable="@drawable/ng_read_aloud_progress"
                android:progress="0" />

            <ImageButton
                android:id="@+id/btn_next_paragraph"
                android:layout_width="42dp"
                android:layout_height="40dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/next_sentence"
                android:padding="9dp"
                android:src="@drawable/ic_read_aloud_fast_forward"
                app:tint="@color/ng_on_surface_variant" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="76dp"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:orientation="horizontal">

            <include
                android:id="@+id/action_bookmark"
                layout="@layout/view_read_aloud_player_action"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/btn_prev"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/previous_chapter"
                android:padding="12dp"
                android:src="@drawable/ic_skip_previous"
                app:tint="@color/ng_on_surface" />

            <ImageButton
                android:id="@+id/btn_play"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginHorizontal="10dp"
                android:background="@drawable/ng_bg_read_aloud_action_circle"
                android:contentDescription="@string/audio_play"
                android:padding="20dp"
                android:src="@drawable/ic_play_24dp"
                app:tint="@color/ng_on_surface" />

            <ImageButton
                android:id="@+id/btn_next"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/next_chapter"
                android:padding="12dp"
                android:src="@drawable/ic_skip_next"
                app:tint="@color/ng_on_surface" />

            <include
                android:id="@+id/action_catalog"
                layout="@layout/view_read_aloud_player_action"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/card_engine"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:background="@drawable/ng_bg_read_aloud_engine_pill"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:minWidth="190dp"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingEnd="14dp">

            <TextView
                android:id="@+id/tv_engine"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:ellipsize="end"
                android:gravity="start|center_vertical"
                android:maxWidth="214dp"
                android:singleLine="true"
                android:text="朗读引擎"
                android:textColor="@color/ng_on_surface"
                android:textSize="15sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_refresh_black_24dp"
                app:tint="@color/ng_on_surface_variant" />
        </LinearLayout>
    </LinearLayout>

    <ImageButton
        android:id="@+id/btn_close"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="start|top"
        android:layout_marginStart="16dp"
        android:layout_marginTop="32dp"
        android:background="@drawable/ng_bg_read_aloud_top_button"
        android:contentDescription="@string/back"
        android:foreground="?android:attr/selectableItemBackgroundBorderless"
        android:padding="8dp"
        android:src="@drawable/ic_read_aloud_chevron_down"
        app:tint="@color/ng_on_surface" />
</FrameLayout>
