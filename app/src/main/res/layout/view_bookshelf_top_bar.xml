<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="10dp"
    android:paddingTop="0dp"
    android:paddingEnd="10dp"
    android:paddingBottom="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_bookshelf_search"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="12dp"
            android:layout_weight="1"
            android:background="@drawable/bg_bookshelf_top_search"
            android:clickable="true"
            android:drawableStart="@drawable/ic_search"
            android:drawablePadding="8dp"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:singleLine="true"
            android:text="@string/search_book_key"
            android:textColor="@color/tv_text_summary"
            android:textSize="13sp" />

        <ImageButton
            android:id="@+id/btn_bookshelf_more"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_bookshelf_top_action"
            android:contentDescription="@string/menu"
            android:padding="8dp"
            android:scaleType="center"
            android:src="@drawable/ic_grid_menu" />

    </LinearLayout>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"
        android:background="@android:color/transparent"
        android:theme="?attr/actionBarStyle"
        app:tabBackground="@android:color/transparent"
        app:tabIndicatorColor="@android:color/transparent"
        app:tabIndicatorHeight="0dp"
        app:tabMaxWidth="0dp"
        app:tabMinWidth="0dp"
        app:tabMode="scrollable"
        app:tabPaddingEnd="3dp"
        app:tabPaddingStart="3dp"
        app:tabRippleColor="@android:color/transparent" />

</LinearLayout>
