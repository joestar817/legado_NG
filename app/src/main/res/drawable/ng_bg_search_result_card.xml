<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/ng_surface_pressed" />
            <stroke
                android:width="0.8dp"
                android:color="@color/ng_card_stroke" />
            <corners android:radius="@dimen/ng_radius_l" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/ng_surface_card" />
            <stroke
                android:width="0.8dp"
                android:color="@color/ng_settings_item_stroke" />
            <corners android:radius="@dimen/ng_radius_l" />
        </shape>
    </item>
</selector>
